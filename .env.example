# ══════════════════════════════════════════════════════════════════
# GLOBAL CONFIGURATION
# ══════════════════════════════════════════════════════════════════
FLASK_ENV=development
SECRET_KEY=yoursecretkeyhere
JWT_SECRET_KEY=super-secret-jwt-key
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=7
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
REDIS_URL=redis://localhost:6379/0

# ══════════════════════════════════════════════════════════════════
# DATA STACK (PostgreSQL & ChromaDB)
# ══════════════════════════════════════════════════════════════════
# PostgreSQL Connection (used by User and ApiKey services)
USER_DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/llm_orchestrator
APIKEY_DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/llm_orchestrator

# ChromaDB Configuration
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_AUTH_TOKEN=changeme-chroma-token

# ══════════════════════════════════════════════════════════════════
# AI & LLM ENGINE
# ══════════════════════════════════════════════════════════════════
# URL to the local Ollama instance (OpenAI-compatible endpoint)
AI_ENGINE_URL=http://localhost:11434/v1/chat/completions

# URL to our AI Orchestration Service
AI_SERVICE_URL=http://localhost:5003

# Default model to use for chat
DEFAULT_CHAT_MODEL=llama3.2:1b

# ══════════════════════════════════════════════════════════════════
# MICROSERVICES
# ══════════════════════════════════════════════════════════════════
# User Service
USER_SERVICE_PORT=5001
USER_SERVICE_LOG_FILE=logs/user_service.log

# ApiKey Service
APIKEY_SERVICE_PORT=5002
APIKEY_SERVICE_LOG_FILE=logs/apikey_service.log

# AI Service
AI_SERVICE_PORT=5003

# Chat Service
CHAT_SERVICE_PORT=5004
CHAT_DATABASE_URL=sqlite:///d:/llm_project/chat.db

# ══════════════════════════════════════════════════════════════════
# CENTRAL MAILER SERVICE (SMTP Settings)
# ══════════════════════════════════════════════════════════════════
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# ══════════════════════════════════════════════════════════════════
# OBSERVABILITY & MONITORING
# ══════════════════════════════════════════════════════════════════
APM_LOGGING_ENABLED=True
LOG_OPTIONS_REQUESTS=False
LOG_LEVEL=INFO
