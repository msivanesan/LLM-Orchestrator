# --- GLOBAL CONFIGURATION ---
FLASK_ENV=development
SECRET_KEY=yoursecretkeyhere
JWT_SECRET_KEY=yoursecretkeyhere
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=7
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30
REDIS_URL=redis://localhost:6379/0

# --- USER MICROSERVICE ---
USER_SERVICE_PORT=5001
DATABASE_URL=sqlite:///d:/llm_project/user.db
USER_SERVICE_LOG_FILE=logs/user_service.log

# --- APIKEY MICROSERVICE ---
APIKEY_SERVICE_PORT=5002
APIKEY_DATABASE_URL=sqlite:///d:/llm_project/apikey.db
APIKEY_SERVICE_LOG_FILE=logs/apikey_service.log

# --- CENTRAL MAILER SERVICE ---
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com

# --- MONITORING ---
APM_LOGGING_ENABLED=True
LOG_OPTIONS_REQUESTS=False
