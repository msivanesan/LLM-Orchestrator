server {
    listen 80;

    # Global CORS Handling
    add_header 'Access-Control-Allow-Origin' 'http://localhost:5173' always;
    add_header 'Access-Control-Allow-Methods' 'GET, POST, OPTIONS, PUT, DELETE, PATCH' always;
    add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization,X-API-KEY' always;
    add_header 'Access-Control-Expose-Headers' 'Content-Length,Content-Range' always;

    # Handle OPTIONS
    if ($request_method = 'OPTIONS') {
        return 204;
    }

    # Docker Resolver (Required for dynamic upstream resolution)
    resolver 127.0.0.11 valid=30s;

    # 1. Identity Manager (User Service)
    location /api/users/ {
        proxy_set_header X-Internal-Service-Key "${INTERNAL_SERVICE_SECRET}";
        proxy_pass http://user:5001/api/users/;
    }

    # 2. Integration Manager (ApiKey Service)
    location /api/apikeys/ {
        proxy_set_header X-Internal-Service-Key "${INTERNAL_SERVICE_SECRET}";
        proxy_pass http://apikey:5002/api/apikeys/;
    }

    # 3. AI ORCHESTRATION LAYER (Secure Access Only)
    location /api/ai/ {
        auth_request /internal/validate;
        proxy_set_header X-Internal-Service-Key "${INTERNAL_SERVICE_SECRET}";
        proxy_pass http://ai:5003/api/ai/;
        
        proxy_read_timeout 300s;
        proxy_connect_timeout 300s;
        proxy_send_timeout 300s;
    }

    # 4. Chat Hub (SSE Streaming Support)
    location /api/chat/ {
        proxy_set_header      X-Internal-Service-Key "${INTERNAL_SERVICE_SECRET}";
        proxy_set_header      Host $host;
        proxy_set_header      X-Real-IP $remote_addr;
        proxy_set_header      X-Forwarded-For $proxy_add_x_forwarded_for;

        proxy_pass            http://chat:5004/api/chat/;
        proxy_read_timeout    300s;
        proxy_connect_timeout 10s;
        proxy_send_timeout    300s;

        # Required for real-time streaming - DISABLE BUFFERING
        proxy_buffering       off;
        proxy_cache           off;
        proxy_http_version    1.1;
        chunked_transfer_encoding on;
    }

    # 5. Security Sidecar (INTERNAL ONLY)
    location = /internal/validate {
        internal;
        proxy_set_header X-Internal-Service-Key "${INTERNAL_SERVICE_SECRET}";
        proxy_pass http://apikey:5002/api/apikeys/validate_header;
        proxy_pass_request_body off;
        proxy_set_header Content-Length "";
        proxy_set_header X-Original-URI $request_uri;
    }

    # 🗃️ UNIFIED ERROR CENTER
    error_page 429 = @rate_limit;
    location @rate_limit { add_header Content-Type application/json; return 429 '{"status": 429, "error": "Too Many Requests", "message": "Slow down! You have reached your quota limit."}'; }

    error_page 500 = @server_error;
    location @server_error { add_header Content-Type application/json; return 500 '{"status": 500, "error": "Internal Server Error", "message": "Service malfunction."}'; }

    error_page 502 = @bad_gateway;
    location @bad_gateway { add_header Content-Type application/json; return 502 '{"status": 502, "error": "Offline", "message": "The system is booting."}'; }

    error_page 403 = @unauthorized;
    location @unauthorized { add_header Content-Type application/json; return 401 '{"status": 401, "error": "Unauthorized", "message": "Invalid API Key."}'; }
}